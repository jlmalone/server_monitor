{
  "pollSeconds": 60,
  "sources": [
    {
      "label": "this Mac",
      "command": ["your-transfer-cli", "queue", "--status", "--json"],
      "runCommand": ["your-transfer-cli", "queue", "--run"]
    }
  ],
  "history": {
    "command": ["your-transfer-cli", "history", "--json"],
    "clearCommand": ["true"]
  },
  "manager": {
    "machines": [
      {"label": "this-mac", "local": true, "start": "/Users/you"},
      {"label": "server", "ssh": "you@server.example", "start": "/srv/media"},
      {"label": "nas", "ssh": "you@nas.example", "start": "/volume1"}
    ],
    "transferCommand": ["your-transfer-helper", "{mode}", "{srcMachine}", "{srcPath}", "{dstMachine}", "{dstPath}"],
    "moveEnabled": true,
    "logDir": "~/.config/server-monitor/transfer-logs",
    "chickletsPath": "~/.config/server-monitor/manager-chicklets.json",
    "maxAttempts": 5,
    "backoffBaseSeconds": 2
  }
}
