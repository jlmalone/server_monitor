# Copy this file to scripts/.env (or project-root .env) and fill in your Apple Developer credentials.
# .env files are gitignored — never commit real credentials.

# Full identity string from your Developer ID Application certificate.
# Find with: security find-identity -v -p codesigning
DEVELOPER_ID_IDENTITY="Developer ID Application: Your Name (TEAMID1234)"

# 10-character Team ID from https://developer.apple.com/account (Membership page).
APPLE_TEAM_ID="TEAMID1234"

# Your Apple ID email (used for notarytool submissions).
APPLE_ID="your.email@example.com"

# App-specific password generated at https://appleid.apple.com
# (Sign-In & Security → App-Specific Passwords). Never reuse your main password.
APPLE_APP_PASSWORD="xxxx-xxxx-xxxx-xxxx"

# Optional: override the bundle identifier.
# BUNDLE_ID="vision.salient.app"
